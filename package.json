{
  "name": "neongambit",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "i18n:check": "node scripts/check-i18n.mjs",
    "i18n:check:refs": "node scripts/check-i18n.mjs --refs",
    "i18n:list:ui": "node scripts/check-i18n.mjs --all",
    "i18n:list:mn": "node scripts/check-i18n.mjs --defined",
    "build:i18n": "npm run build && npm run i18n:check",
    "test:language": "node scripts/test-language-persistence.mjs",
    "test:language:e2e": "node scripts/test-language-with-backend.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate:ratings:pools": "npm --prefix server run migrate:ratings:pools --",
    "migrate:ratings:pools:dry": "npm --prefix server run migrate:ratings:pools -- --dry-run",
    "migrate:user-languages": "npm --prefix server run migrate:user-languages --",
    "migrate:user-languages:dry": "npm --prefix server run migrate:user-languages -- --dry-run",
    "seed:leaderboard": "npm --prefix server run seed:leaderboard --",
    "seed:leaderboard:dry": "npm --prefix server run seed:leaderboard -- --dry-run"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.22",
    "@headlessui/react": "^1.7.18",
    "ai": "^4.3.16",
    "cannon-es": "^0.20.0",
    "chess.js": "^0.13.4",
    "clsx": "^2.1.0",
    "framer-motion": "^11.0.8",
    "gsap": "^3.13.0",
    "i18next": "^23.10.1",
    "i18next-browser-languagedetector": "^7.2.0",
    "lucide-react": "^0.533.0",
    "matter-js": "^0.20.0",
    "react": "^18.3.1",
    "react-chessboard": "^4.7.2",
    "react-dom": "^18.3.1",
    "react-i18next": "^14.1.0",
    "react-router-dom": "^6.30.1",
    "react-use": "^17.6.0",
    "recharts": "^3.7.0",
    "socket.io-client": "^4.7.5",
    "three": "^0.179.1",
    "zod": "^3.25.67",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/matter-js": "^0.20.0",
    "@types/node": "^24.0.14",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.5.2",
    "@youware/vite-plugin-react": "^1.0.3",
    "autoprefixer": "^10.4.21",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "vite": "^7.0.0",
    "vitest": "^3.2.4"
  }
}
